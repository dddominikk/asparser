{
  "name": "asparser",
  "version": "0.1.0",
  "private": false,
  "description": "Fetch > resolve > parse.",
  "keywords": [
    "parser",
    "data string",
    "load data",
    "esm",
    "modules",
    "safe eval"
  ],
  "homepage": "https://github.com/dddominikk/asparser#readme",
  "bugs": {
    "url": "https://github.com/dddominikk/asparser/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dddominikk/asparser.git"
  },
  "license": "MIT",
  "author": "Dominik Bošnjak <bosnjakinimod@gmail.com>",
  "type": "module",
  "exports": {
    ".": {
      "browser": "./src/browser.ts",
      "default": "./src/node.ts"
    },
    "./browser": "./src/browser.ts",
    "./node": "./src/node.ts",
    "./core": "./src/index.ts"
  },
  "main": "./src/node.ts",
  "browser": "./src/browser.ts",
  "scripts": {
    "start": "node --experimental-strip-types src/node.ts",
    "remoteParser": "node src/core/ "
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "ttypescript": "^1.5.15",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "publishConfig": {},
  "devEngines": {
    "packageManager": {
      "name": "node",
      "version": ">=22.18.0",
      "onFail": "warn"
    }
  },
  "publisher": "dddb"
}